# Plesk Apache Configuration for raco-backend
# Place this file in: /var/www/vhosts/raco-backend.madrasah.dev/httpdocs/.htaccess

RewriteEngine On

# Proxy API documentation and endpoints to Node.js app on port 4000
RewriteRule ^api-docs$ http://localhost:4000/api-docs [P,L]
RewriteRule ^api-json$ http://localhost:4000/api-json [P,L]
RewriteRule ^api/(.*)$ http://localhost:4000/api/$1 [P,L]
RewriteRule ^postman$ http://localhost:4000/postman [P,L]
RewriteRule ^api-info$ http://localhost:4000/api-info [P,L]

# Serve static files if they exist (but don't proxy them)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Redirect HTTP to HTTPS (uncomment if SSL is working)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
