# ===========================================
# raco-backend — ENVIRONMENT TEMPLATE
# ✅ COMMIT THIS FILE
# Copy this file to .env and fill in your values
# ===========================================

# ===========================================
# Application Info
# ===========================================
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# ===========================================
# Database Configuration (PostgreSQL via Prisma)
# ===========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/db?schema=public

# ===========================================
# Redis Configuration (category-tree DFS cache)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CATEGORY_TREE_TTL=3600

# ===========================================
# JWT Authentication
# ===========================================
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# Password Hashing (Bcrypt)
# ===========================================
BCRYPT_SALT_ROUNDS=12

# ===========================================
# Stripe Payment Gateway (Test mode)
# Get keys from: https://dashboard.stripe.com/test/apikeys
# ===========================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Run: stripe listen --forward-to localhost:4000/api/v1/payments/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_API_VERSION=2024-12-18.acacia
STRIPE_CURRENCY=bdt

# ===========================================
# bKash Payment Gateway (Sandbox)
# Get credentials from: https://developer.bka.sh/
# ===========================================
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
# Must be a publicly reachable URL — use ngrok locally
# e.g. https://abc123.ngrok-free.app/api/v1/payments/bkash/callback
BKASH_CALLBACK_URL=http://localhost:4000/api/v1/payments/bkash/callback

# ===========================================
# AWS S3 Configuration (Product Image Storage)
# ===========================================
AWS_BUCKET="your-bucket-name-here"
AWS_DEFAULT_REGION="your-region-here"
AWS_ACCESS_KEY_ID="your-access-key-id-here"
AWS_SECRET_ACCESS_KEY="your-secret-access-key-here"
AWS_ENDPOINT="your-s3-endpoint-here"
AWS_CDN_URL="your-cdn-url-here"
AWS_USE_PATH_STYLE_ENDPOINT="false"
AWS_S3_MAX_FILE_SIZE=5242880
AWS_S3_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif

# ===========================================
# Local Development Options
# ===========================================
# Option A: Create a real AWS S3 bucket (free tier — 5 GB)
#   → Fill AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY above
# Option B: Run LocalStack for a local S3 mock
#   → docker run -p 4566:4566 localstack/localstack
#   → Set AWS_S3_ENDPOINT=http://localhost:4566 below
# AWS_S3_ENDPOINT=http://localhost:4566   ← uncomment for LocalStack only

# ===========================================
# CORS Configuration
# ===========================================
ALLOWED_ORIGINS=http://localhost:3000

# ===========================================
# Swagger / API Documentation
# ===========================================
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
SWAGGER_TITLE=Raco E-commerce API
SWAGGER_DESCRIPTION=E-commerce Ordering & Payment System
SWAGGER_VERSION=1.0.0

# ===========================================
# Logging Configuration
# ===========================================
LOG_LEVEL=debug
REQUEST_ID_HEADER=x-request-id

# ===========================================
# Docker Compose Configuration
# (used only by docker-compose.yml)
# ===========================================
POSTGRES_USER=user
POSTGRES_PASSWORD=
POSTGRES_DB=db
