# ─────────────────────────────────────────────────────────────────
# raco-backend — ENVIRONMENT TEMPLATE
# ✅ COMMIT THIS FILE
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# ─── Database (PostgreSQL via Prisma) ─────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/raco_db?schema=public

# ─── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CATEGORY_TREE_TTL=3600

# ─── JWT ──────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# ─── Bcrypt ───────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ─── Stripe (Test mode — https://dashboard.stripe.com/test/apikeys) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Run: stripe listen --forward-to localhost:4000/api/v1/payments/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_API_VERSION=2024-12-18.acacia
STRIPE_CURRENCY=bdt

# ─── bKash (Sandbox — https://developer.bka.sh/) ──────────────────
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
# Must be a publicly reachable URL — use ngrok locally
# e.g. https://abc123.ngrok-free.app/api/v1/payments/bkash/callback
BKASH_CALLBACK_URL=http://localhost:4000/api/v1/payments/bkash/callback

# ─── AWS S3 (Product Image Storage) ──────────────────────────────
# Region: ap-southeast-1 (Singapore) is closest to Bangladesh
# IAM policy: s3:PutObject, s3:GetObject, s3:DeleteObject
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=raco-product-images
# Uncomment only if using LocalStack locally
# AWS_S3_ENDPOINT=http://localhost:4566
# Uncomment only if using CloudFront CDN instead of direct S3 URL
# AWS_S3_BASE_URL=https://YOUR_CLOUDFRONT_DOMAIN
AWS_S3_MAX_FILE_SIZE=5242880
AWS_S3_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif

# ─── CORS ─────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ─── Swagger ──────────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
SWAGGER_TITLE=Raco E-commerce API
SWAGGER_DESCRIPTION=E-commerce Ordering & Payment System
SWAGGER_VERSION=1.0.0

# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=debug
REQUEST_ID_HEADER=x-request-id

# ─── Docker Compose DB vars ───────────────────────────────────────
POSTGRES_USER=raco_user
POSTGRES_PASSWORD=
POSTGRES_DB=raco_db
