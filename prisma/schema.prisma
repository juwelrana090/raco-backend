generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  STRIPE
  BKASH
}

// ─── File Manager ─────────────────────────────────────────────────
// Tracks every file uploaded to S3.
// fileUse = what the file is for (e.g. 'product-image', 'category-image')
// filePath = S3 key (used for deletion — never extract from URL)
model FileManager {
  id            Int      @id @default(autoincrement())
  fileName      String   @map("file_name")
  fileType      String   @map("file_type")       // 'image' | 'document' | 'video'
  fileFormat    String   @map("file_format")     // 'jpg' | 'png' | 'webp' | 'gif'
  fileThumbnail String?  @map("file_thumbnail")
  filePath      String   @map("file_path")       // S3 key e.g. raco/products/uuid.jpg
  fileUse       String   @map("file_use")        // context e.g. 'product-image'
  fileWidth     Int?     @map("file_width")
  fileHeight    Int?     @map("file_height")
  fileBucket    String?  @map("file_bucket")
  fileUrl       String?  @map("file_url")        // full S3 URL
  fileCdnUrl    String?  @map("file_cdn_url")    // CDN URL (preferred)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  products Product[]

  @@map("file_manager")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders        Order[]
  refreshTokens RefreshToken[]

  @@index([email])
}

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  parentId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children Category[] @relation("CategoryHierarchy")
  products Product[]

  @@index([parentId])
}

model Product {
  id            String  @id @default(uuid())
  sku           String  @unique
  name          String
  description   String?
  price         Int
  stock         Int     @default(0)
  imageUrl      String? @map("image_url")       // CDN URL — shortcut for display
  fileManagerId Int?    @map("file_manager_id") // FK to FileManager for deletion
  categoryId    String  @map("category_id")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  fileManager FileManager? @relation(fields: [fileManagerId], references: [id], onDelete: SetNull)
  orderItems  OrderItem[]

  @@index([categoryId])
  @@index([sku])
  @@index([fileManagerId])
}

model Order {
  id          String      @id @default(uuid())
  userId      String
  totalAmount Int
  status      OrderStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    OrderItem[]
  payments Payment[]

  @@index([userId])
  @@index([status])
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Int
  createdAt DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id            String          @id @default(uuid())
  orderId       String
  provider      PaymentProvider
  providerTxnId String?         @unique
  amount        Int
  status        PaymentStatus   @default(PENDING)
  rawResponse   String?         @db.Text
  metadata      String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, provider])
  @@index([orderId])
  @@index([providerTxnId])
  @@index([status])
}
